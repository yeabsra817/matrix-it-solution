# =============================================================================
# Matrix Modern Banking KPI Tracker — Environment Variables
# =============================================================================
# Copy to backend/.env and frontend/.env.local for local development.
# Set these in Vercel (frontend) and Railway/Render (backend) for production.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (Vercel) — set in Project Settings → Environment Variables
# -----------------------------------------------------------------------------

# Server-side only: Express API URL for Next.js rewrites (NOT exposed to browser)
# Production example: https://matrix-kpi-api.up.railway.app
API_URL=http://localhost:4000

# Optional: override public API URL (leave UNSET in production to use same-origin proxy)
# Only needed if NOT using Next.js rewrites
# NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# BACKEND (Railway / Render) — set in service Environment Variables
# -----------------------------------------------------------------------------

PORT=4000
NODE_ENV=production

# PostgreSQL (Supabase, Railway Postgres, Neon, etc.)
# Supabase example:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matrix_banking_kpi

# Enable SSL for managed PostgreSQL (auto-enabled when NODE_ENV=production)
DATABASE_SSL=true
DATABASE_POOL_MAX=10

# Auth — use a strong random string (32+ characters) in production
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRES_IN=24h

# Comma-separated allowed origins (your Vercel URL + preview URLs)
# Example: https://matrix-kpi.vercel.app,https://matrix-kpi-*.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# SUPER ADMIN (created by npm run seed)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=yeabsra45@gmail.com
SUPER_ADMIN_PASSWORD=227387
SUPER_ADMIN_NAME=Yeabsra Teffera

# Demo bank users password (optional)
DEMO_USER_PASSWORD=Password123!
